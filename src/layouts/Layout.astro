---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  lang?: 'es' | 'en';
}

const {
  title = 'Guillermo Hernandez | Full Stack Developer',
  description = 'Guillermo Hernandez - Full Stack Developer con +4 anos de experiencia en TypeScript, React, Next.js, Node.js, NestJS, AWS, MongoDB, Docker. E-commerce, fintech y automatizacion.',
  lang = 'es'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('og-image.png', Astro.site + (Astro.site?.toString().endsWith('/') ? '' : '/'));

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Guillermo Hernandez",
  "url": "https://ghezdev.github.io/cv/",
  "image": ogImage.toString(),
  "jobTitle": "Full Stack Developer",
  "description": "Full Stack Developer with 4+ years of experience in e-commerce, fintech, and process automation. TypeScript, React, Node.js, AWS.",
  "worksFor": {
    "@type": "Organization",
    "name": "LA NACION",
    "url": "https://www.lanacion.com.ar"
  },
  "email": "hernandez17.guillermo@gmail.com",
  "telephone": "+5491124678502",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Buenos Aires",
    "addressRegion": "CABA",
    "addressCountry": "AR"
  },
  "sameAs": [
    "https://www.linkedin.com/in/ghez/",
    "https://github.com/ghezdev"
  ],
  "alumniOf": [
    { "@type": "CollegeOrUniversity", "name": "Universidad Argentina de la Empresa", "url": "https://www.uade.edu.ar" },
    { "@type": "EducationalOrganization", "name": "E.T. N1 Ing. Otto Krause" }
  ],
  "hasCredential": {
    "@type": "EducationalOccupationalCredential",
    "name": "Google Cloud Computing Foundations Certificate",
    "credentialCategory": "certificate",
    "recognizedBy": { "@type": "Organization", "name": "Google Cloud" }
  },
  "knowsAbout": [
    "TypeScript", "JavaScript", "Python", "React", "Next.js", "Node.js",
    "NestJS", "Express", "AWS", "Google Cloud", "MongoDB", "PostgreSQL",
    "MySQL", "Docker", "REST APIs", "GraphQL", "CI/CD", "TailwindCSS"
  ],
  "knowsLanguage": [
    { "@type": "Language", "name": "Spanish", "alternateName": "es" },
    { "@type": "Language", "name": "English", "alternateName": "en" }
  ],
  "hasOccupation": {
    "@type": "Occupation",
    "name": "Full Stack Developer",
    "occupationLocation": { "@type": "Country", "name": "Argentina" },
    "skills": "TypeScript, React, Next.js, Node.js, NestJS, AWS, MongoDB, PostgreSQL, Docker"
  }
};
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="Full Stack Developer, TypeScript, React, Next.js, Node.js, NestJS, AWS, MongoDB, PostgreSQL, Docker, JavaScript, Python, Buenos Aires, Argentina" />
    <meta name="author" content="Guillermo Hernandez" />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={lang === 'es' ? 'es_AR' : 'en_US'} />
    <meta property="og:site_name" content="Guillermo Hernandez CV" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`.replace('//', '/')} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap" rel="stylesheet" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="min-h-screen bg-white dark:bg-zinc-950 text-zinc-800 dark:text-zinc-100 font-sans antialiased print:bg-white print:text-black">
    <slot />

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.setAttribute('data-visible', 'true');
              }
            });
          },
          { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
        );
        document.querySelectorAll('[data-animate]').forEach((el) => observer.observe(el));

        document.getElementById('print-cv-btn')?.addEventListener('click', () => {
          window.print();
        });
      });
    </script>
  </body>
</html>
