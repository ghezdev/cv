<script is:inline>
  (function () {
    const translations = {
      es: {
        nav: { about: 'Perfil', experience: 'Experiencia', education: 'Formación', certifications: 'Certificaciones', skills: 'Habilidades', contact: 'Contacto' },
        hero: { printCv: 'Imprimir CV' },
        sections: { about: 'Resumen Profesional', experience: 'Experiencia Profesional', education: 'Formación Académica', certifications: 'Certificaciones', skills: 'Habilidades Técnicas', softSkills: 'Habilidades Blandas', contact: 'Contacto' },
        experience: { present: 'Actual', downloadCv: 'Descargar CV' },
        dates: { present: 'Actual' },
        contact: { title: '¿Interesado en trabajar juntos?', description: 'Estoy abierto a nuevas oportunidades, proyectos desafiantes y colaboraciones. No dudes en contactarme.', email: 'Email', phone: 'Teléfono', location: 'Ubicación', getInTouch: 'Contactar por LinkedIn' },
        footer: { rights: 'Todos los derechos reservados.', builtWith: 'Hecho con Astro' },
        cert: { issued: 'Emitido', viewCredential: 'Ver credencial' }
      },
      en: {
        nav: { about: 'Profile', experience: 'Experience', education: 'Education', certifications: 'Certifications', skills: 'Skills', contact: 'Contact' },
        hero: { printCv: 'Print CV' },
        sections: { about: 'Professional Summary', experience: 'Professional Experience', education: 'Education', certifications: 'Certifications', skills: 'Technical Skills', softSkills: 'Soft Skills', contact: 'Contact' },
        experience: { present: 'Present', downloadCv: 'Download CV' },
        dates: { present: 'Present' },
        contact: { title: 'Interested in working together?', description: "I'm open to new opportunities, challenging projects and collaborations. Don't hesitate to reach out.", email: 'Email', phone: 'Phone', location: 'Location', getInTouch: 'Contact on LinkedIn' },
        footer: { rights: 'All rights reserved.', builtWith: 'Built with Astro' },
        cert: { issued: 'Issued', viewCredential: 'View credential' }
      }
    };

    function applyTranslations(lang) {
      const t = translations[lang];
      if (!t) return;
      document.querySelectorAll('[data-i18n]').forEach((el) => {
        const key = el.getAttribute('data-i18n');
        if (!key) return;
        const keys = key.split('.');
        let value = t;
        for (const k of keys) value = value && value[k];
        if (typeof value === 'string') el.textContent = value;
      });
      document.querySelectorAll('[data-i18n-es], [data-i18n-en]').forEach((el) => {
        const attr = lang === 'es' ? 'data-i18n-es' : 'data-i18n-en';
        const value = el.getAttribute(attr);
        if (value !== null) el.textContent = value;
      });
      document.querySelectorAll('.lang-btn').forEach((btn) => {
        const langAttr = btn.getAttribute('data-lang');
        const isActive = langAttr === lang;
        btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        btn.classList.toggle('!bg-indigo-600', isActive);
        btn.classList.toggle('!text-white', isActive);
      });
      document.documentElement.lang = lang;
      localStorage.setItem('lang', lang);
    }

    document.addEventListener('DOMContentLoaded', () => {
      const saved = localStorage.getItem('lang') || 'es';
      applyTranslations(saved);
      document.querySelectorAll('.lang-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          const lang = btn.getAttribute('data-lang');
          if (lang) applyTranslations(lang);
        });
      });
    });
  })();
</script>
